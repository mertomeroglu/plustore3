{{ 'section-header.css' | asset_url | stylesheet_tag }}

<div class="skeleton-header{% if section.settings.header_sticky %} skeleton-header--sticky{% endif %}">
  <div class="skeleton-topbar">
    <div class="container skeleton-topbar__inner">
      <div class="skeleton-topbar__welcome">{{ section.settings.header_welcome }}</div>
      {%- if section.settings.top_enable and section.settings.nav_linklist != blank -%}
        <ul class="skeleton-topbar__links list-menu--inline no-bullet">
          {%- for link in linklists[section.settings.nav_linklist].links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>

  <div class="skeleton-mainbar">
    <div class="container skeleton-mainbar__inner">
      <a href="{{ routes.root_url }}" class="skeleton-logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank or section.settings.logo_mobile != blank -%}
          <picture>
            {%- if section.settings.logo_mobile != blank -%}
              <source media="(max-width: 767px)" srcset="{{ section.settings.logo_mobile | image_url: width: section.settings.logo_mobile_width | default: 150 }}">
            {%- endif -%}
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width | default: 200 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width | default: 200 }}" loading="lazy">
            {%- else -%}
              <img src="{{ section.settings.logo_mobile | image_url: width: section.settings.logo_mobile_width | default: 150 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_mobile_width | default: 150 }}" loading="lazy">
            {%- endif -%}
          </picture>
        {%- else -%}
          <span>{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <search-form class="skeleton-search">
        {%- liquid
          assign searchUrl = search.terms | split:'product_type:'
          assign searchTerms = searchUrl[0] | strip
          assign searchType = searchUrl[1] | strip
        -%}
        <form action="{{ routes.search_url }}" method="get" role="search" class="skeleton-search__form">
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[unavailable_products]" value="hide">
          <input type="hidden" name="options[prefix]" value="last">
          <input type="text" name="q" class="skeleton-search__input" placeholder="{{ 'general.search.placeholder' | t }}" value="{{ searchTerms }}">
          {%- if section.settings.search_type and shop.types.size > 0 -%}
            <div class="skeleton-search__select-wrap">
              <select name="product_type" class="skeleton-search__select">
                <option value="*">{{ 'general.search.all_types' | t }}</option>
                {%- for product_type in shop.types -%}
                  {%- if product_type == blank %}{% continue %}{% endif -%}
                  <option value="{{ product_type }}" {% if searchType == product_type %}selected="selected"{% endif %}>{{ product_type }}</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endif -%}
          <button class="skeleton-search__submit" type="submit" aria-label="{{ 'general.search.search' | t }}">
            <span class="cs-icon icon-search"></span>
          </button>
        </form>
      </search-form>

      <div class="skeleton-actions">
        {%- if section.settings.contact_enable and section.settings.contact_phone != blank -%}
          <a class="skeleton-actions__item" href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone }}</a>
        {%- endif -%}
        {%- if shop.customer_accounts_enabled -%}
          <a class="skeleton-actions__item" href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">
            {%- if customer -%}{{ 'customer.account_fallback' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}
          </a>
        {%- endif -%}
        <a class="skeleton-actions__item skeleton-actions__cart" href="{{ routes.cart_url }}">
          <span class="cs-icon icon-cs-cart"></span>
          <span>{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>

  <div class="skeleton-nav">
    <div class="container skeleton-nav__inner">
      {%- if section.settings.header_categorie and section.settings.categorie_link_list != blank -%}
        <details class="skeleton-categories">
          <summary>{{ section.settings.categorie_title | default: 'Kategoriler' }}</summary>
          <ul>
            {%- for link in linklists[section.settings.categorie_link_list].links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </details>
      {%- endif -%}

      {%- if section.settings.link_list != blank -%}
        <ul class="skeleton-nav__menu list-menu--inline no-bullet">
          {%- for link in linklists[section.settings.link_list].links -%}
            <li><a href="{{ link.url }}" {% if link.current %}aria-current="page"{% endif %}>{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = shop.url | append: routes.search_url | append: "?q={search_term_string}" %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ shop.url | append: page.url | json }}
    }
  </script>
{%- endif -%}
